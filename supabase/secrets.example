# Set via: supabase secrets set --env-file supabase/.env.secrets
# Or individually in Supabase Dashboard → Edge Functions → Secrets

JWT_SECRET=your-jwt-secret-min-32-chars
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

FRONTEND_URL=https://sphere-perps.vercel.app
ADMIN_WALLET_PUBKEYS=

SPHERE_TREASURY_NAMETAG=sphere-perps-treasury
# SPHERE_TREASURY_MNEMONIC=  # optional — withdrawals mock without it

AI_PROVIDER=mock
# AI_API_KEY=

# Cron invocations should pass this header
CRON_SECRET=your-cron-secret